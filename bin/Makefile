#	Install the various links to bin - add this directory to
#	your path and the commands are directly available.
#

install	:
	-rm dkbs masc mp rem_dkb_svc readertool reader masc rem_inst_svc wintool
	-ln -s ../dkbs/dkbs
	-ln -s ../dkbs/rpcs/rem_dkb_svc
	-ln -s ../io/readertool
	-ln -s ../io/reader
	-ln -s ../masc/masc
	-ln -s ../masc/rpcs/rem_inst_svc
	-ln -s ../mp/mp
	-ln -s ../io/wintool

